{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lcurl"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Remote build",
            "problemMatcher": [
                "$gcc"
            ],
            "type": "shell",
            "command": "ssh -tt chris@192.168.50.190 'cd ~/Desktop/HouseTempNotification && gcc -g fixed.c -o fixed -lcurl'"
        },
        {
            "label": "Remote run",
            "problemMatcher": [
                "$gcc"
            ],
            "type": "shell",
            "command": "ssh -tt chris@192.168.50.190 'cd ~/Desktop/HouseTempNotification && gcc -g fixed.c -o fixed -lcurl && ./fixed'"
        },
        {
            "label": "Remote kill fixed",
            "type": "shell",
            "command": "ssh chris@192.168.50.190 'pgrep -a fixed && pkill -INT -x fixed || echo \"fixed not running\"'",
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}